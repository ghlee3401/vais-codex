{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh hooks/session-start.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/bash-guard.js",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/doc-tracker.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "hooks/run-node.sh hooks/ideation-guard.js",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "사용자 확인",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/cp-tracker.js",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/stop-handler.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/agent-start.js ${AGENT_NAME:-unknown} ${PHASE:-unknown}",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-node.sh scripts/agent-stop.js ${AGENT_NAME:-unknown} ${OUTCOME:-success}",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
