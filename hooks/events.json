{
  "version": "3.0.0",
  "description": "vais event-log.jsonl 이벤트 스키마 문서. MCP 서버 + 대시보드 소비용",
  "events": {
    "session_start": {
      "description": "새 피처 개발 세션 시작",
      "payload": ["feature", "c_suite"],
      "required": ["feature"]
    },
    "session_end": {
      "description": "세션 종료",
      "payload": ["feature", "outcome"],
      "required": ["feature"]
    },
    "agent_start": {
      "description": "에이전트 실행 시작",
      "payload": ["role", "phase", "task"],
      "required": ["role", "phase"]
    },
    "agent_stop": {
      "description": "에이전트 완료/실패",
      "payload": ["role", "outcome", "doc"],
      "required": ["role", "outcome"]
    },
    "phase_transition": {
      "description": "단계 전환 (plan→design 등)",
      "payload": ["from", "to", "feature"],
      "required": ["from", "to", "feature"]
    },
    "gate_check": {
      "description": "Gate 판정",
      "payload": ["gate", "result", "items"],
      "required": ["gate", "result"]
    },
    "decision": {
      "description": "C-Suite 결정 기록",
      "payload": ["role", "type", "choice", "rationale"],
      "required": ["role", "type", "choice"]
    },
    "error": {
      "description": "에러 발생",
      "payload": ["role", "code", "message"],
      "required": ["role", "message"]
    },
    "ideation_started": {
      "description": "Ideation 세션 시작 (v0.50)",
      "payload": ["timestamp", "feature", "initiator", "role", "topic"],
      "required": ["timestamp", "feature", "initiator", "role", "topic"]
    },
    "ideation_ended": {
      "description": "Ideation 세션 종료 (v0.50)",
      "payload": ["timestamp", "feature", "output_path", "status", "turn_count", "duration_sec"],
      "required": ["timestamp", "feature", "output_path", "status"]
    },
    "advisor_call": {
      "description": "Advisor 도구 호출 (v0.50 M-24)",
      "payload": ["timestamp", "session_id", "sub_agent", "c_level", "trigger", "tokens_in", "tokens_out", "cached_tokens", "cost", "status"],
      "required": ["timestamp", "session_id", "sub_agent", "c_level", "trigger", "tokens_in", "tokens_out", "cached_tokens", "cost", "status"]
    },
    "advisor_degraded": {
      "description": "Advisor 비용 캡 초과 비활성화 (v0.50)",
      "payload": ["timestamp", "session_id", "reason", "fallback_model", "monthly_spent", "cap", "next_reset"],
      "required": ["timestamp", "session_id", "reason"]
    },
    "advisor_budget_block": {
      "description": "Advisor 예산 차단 (v0.50)",
      "payload": ["timestamp", "session_id", "sub_agent", "total_spent", "cap", "remaining"],
      "required": ["timestamp", "session_id", "sub_agent"]
    },
    "role_transition": {
      "description": "C-Level 역할 전환 (v0.50)",
      "payload": ["from_role", "to_role", "reason", "feature"],
      "required": ["from_role", "to_role", "reason", "feature"]
    },
    "phase_transition_auto": {
      "description": "Phase 자동 전이 — gate 통과 후 (v0.50)",
      "payload": ["feature", "fromPhase", "toPhase", "reason"],
      "required": ["feature", "fromPhase", "toPhase", "reason"]
    },
    "phase_transition_retry": {
      "description": "Phase 전이 실패 → 재시도 (v0.50)",
      "payload": ["feature", "phase", "failures"],
      "required": ["feature", "phase", "failures"]
    },
    "gate_judgment": {
      "description": "4-step gate 판정 결과 (v0.50)",
      "payload": ["feature", "phase", "result", "reason"],
      "required": ["feature", "phase", "result", "reason"]
    }
  }
}
