#!/bin/sh
# VAIS Code — pre-commit hook
# git config core.hooksPath .hooks 으로 활성화 (npm run prepare-hooks)
set -e

echo "[VAIS] Running pre-commit checks..."

# ── legacy-path-guard ──────────────────────────────────────────────
# @see scripts/check-legacy-paths.sh (single source of exception list)
bash scripts/check-legacy-paths.sh --mode=staged

# ── ESLint ─────────────────────────────────────────────────────────
if command -v npx > /dev/null 2>&1; then
  npx eslint scripts/ lib/ hooks/ --max-warnings=0
  echo "[VAIS] ESLint passed."
fi

# ── Unit tests ─────────────────────────────────────────────────────
node --test tests/*.test.js
echo "[VAIS] Tests passed."
