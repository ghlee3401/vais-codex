{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-process-exit": "off"
  },
  "ignorePatterns": ["vendor/", "node_modules/", "design-system/", "docs/"]
}
